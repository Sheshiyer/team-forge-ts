# Copy to .env (gitignored) and fill in. NEVER commit real values.

# ─── Huly connection ─────────────────────────────────────
# Huly Cloud transactor URL (default). For self-hosted, set to your endpoint.
HULY_URL=wss://transactor.huly.app

# Workspace UUID (extract from your JWT payload "workspace" field)
# Decode at https://jwt.io to find — payload has { account, workspace }
HULY_WORKSPACE=

# JWT token from Huly. Generate via Huly settings → API tokens.
# ROTATE IMMEDIATELY if exposed (e.g. pasted in chat).
HULY_TOKEN=

# ─── GitHub source for sync ──────────────────────────────
GITHUB_REPO=Sheshiyer/parkarea-aleph
# Set via: GITHUB_TOKEN=$(gh auth token)
GITHUB_TOKEN=
